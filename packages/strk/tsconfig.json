{
  "compilerOptions": {
    "lib": ["DOM", "ES2022", "DOM.Iterable"],
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "moduleResolution": "bundler",
    "moduleDetection": "force",

    "baseUrl": ".",
    "paths": {
      "@/*": ["./*", "./src/*"]
    }
  },
  "include": [".eslintrc.cjs", "src/**/*.ts", "src/**/*.tsx", "scripts/**/*.ts"]
}
