{
  "name": "@trezo/evm",
  "description": "A type-safe toolkit for interacting with EVM smart contracts and wallets in modern frontend applications.",
  "version": "1.6.0",
  "author": "thelastofinusa",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "keywords": [
    "trezo",
    "web3",
    "evm",
    "ethereum",
    "blockchain",
    "dapp",
    "wagmi",
    "viem",
    "ethers",
    "connectkit",
    "reown",
    "appkit",
    "react",
    "vue",
    "svelte",
    "angular",
    "nextjs",
    "type-safe",
    "abi"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./plugins/vite": {
      "types": "./dist/plugins/vite.d.ts",
      "import": "./dist/plugins/vite.mjs",
      "require": "./dist/plugins/vite.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "genomodal": "tsx scripts/genomodal.ts",
    "publish:default": "npm publish --access public",
    "publish:increment": "npm version patch --no-git-tag-version && npm publish --access public"
  },
  "homepage": "https://trezosite.vercel.app/docs/packages/evm",
  "bugs": {
    "url": "https://github.com/trezo-labs/packages/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trezo-labs/packages.git"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.mjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.mts",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "abitype": "^1.2.3",
    "ethers": "^6.16.0",
    "wagmi": "^2.14.16",
    "viem": "^2.47.6",
    "@wagmi/core": "^2.16.7",
    "@wagmi/connectors": "^5.7.7",
    "@tanstack/react-query": "^5.95.2",
    "connectkit": "^1.9.2",
    "@reown/appkit": "^1.8.19",
    "@reown/appkit-adapter-wagmi": "^1.8.19"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "vue": ">=3",
    "svelte": ">=4",
    "@angular/core": ">=16",
    "@angular/common": ">=16",
    "rxjs": ">=7"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "@angular/common": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
