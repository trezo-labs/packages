{
  "name": "@trezo/evm",
  "description": "A type-safe toolkit for interacting with EVM smart contracts and wallets in modern frontend applications.",
  "version": "1.5.17",
  "author": "thelastofinusa",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "keywords": [
    "trezo",
    "web3",
    "evm",
    "ethereum",
    "blockchain",
    "dapp",
    "state-management",
    "ethers",
    "wagmi",
    "viem",
    "connectkit",
    "reown",
    "appkit",
    "react",
    "nextjs",
    "type-safe",
    "abi"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./plugins/vite": {
      "types": "./dist/plugins/vite.d.ts",
      "import": "./dist/plugins/vite.mjs",
      "require": "./dist/plugins/vite.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "genomodal": "tsx scripts/genomodal.ts",
    "publish-package": "npm version patch --no-git-tag-version && npm publish --access public"
  },
  "homepage": "https://trezosite.vercel.app/docs/packages/evm",
  "bugs": {
    "url": "https://github.com/trezo-labs/packages/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trezo-labs/packages.git"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.mjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.mts",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "abitype": "^1.2.3",
    "ethers": "^6.16.0",
    "wagmi": "^2.14.16",
    "viem": "^2.47.6",
    "@wagmi/core": "^2.16.7",
    "@wagmi/connectors": "^5.7.7",
    "@tanstack/react-query": "^5.95.2",
    "connectkit": "^1.9.2",
    "@reown/appkit": "^1.8.19",
    "@reown/appkit-adapter-wagmi": "^1.8.19"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "pnpm": {
    "overrides": {
      "utf-8-validate": "^5.0.2",
      "zod": "^3.22.0",
      "@wagmi/connectors": "^5.11.2",
      "@wagmi/core": "^2.22.1"
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
