{
  "name": "@trezo/evm",
  "description": "A type-safe toolkit for interacting with EVM smart contracts and wallets in modern frontend applications.",
  "version": "1.0.1",
  "keywords": [
    "trezo",
    "web3",
    "evm",
    "ethereum",
    "blockchain",
    "dapp",
    "state-management",
    "ethers",
    "wagmi",
    "viem",
    "connectkit",
    "reown",
    "appkit",
    "react",
    "nextjs",
    "type-safe",
    "abi"
  ],
  "author": "thelastofinusa",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "prepublishOnly": "npm run build",
    "genokit": "tsx scripts/genokit.ts",
    "typecheck": "tsc --noEmit",
    "publish-package": "npm version patch --no-git-tag-version && npm publish --access public"
  },
  "homepage": "https://trezosite.vercel.app/docs/packages/evm",
  "bugs": {
    "url": "https://github.com/trezo-labs/packages/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trezo-labs/packages.git"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.mjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.mts",
    "LICENSE",
    "README.md"
  ],
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "dependencies": {
    "@reown/appkit": "^1.6.8",
    "@reown/appkit-adapter-wagmi": "^1.6.8",
    "@tanstack/react-query": "^5.90.21",
    "abitype": "^1.2.3",
    "bufferutil": "^4.0.9",
    "connectkit": "^1.9.1",
    "ethers": "^6.16.0",
    "react-is": "^19.0.0",
    "utf-8-validate": "^5.0.2",
    "viem": "^2.21.0",
    "wagmi": "^2.14.9"
  },
  "devDependencies": {
    "@metamask/providers": "^22.1.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
