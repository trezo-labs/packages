{
  "compilerOptions": {
    "lib": ["DOM", "ES2022", "DOM.Iterable"],
    "esModuleInterop": true,
    "module": "ESNext",
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "moduleResolution": "bundler",
    "moduleDetection": "force",

    "baseUrl": ".",
    "paths": {
      "@/*": ["./*", "./src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
