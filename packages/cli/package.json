{
  "name": "trezo",
  "description": "The entry point for creating and configuring Trezo applications.",
  "version": "1.0.5",
  "author": "thelastofinusa",
  "license": "MIT",
  "main": "./dist/cli.js",
  "module": "./dist/cli.mjs",
  "types": "./dist/cli.d.ts",
  "bin": {
    "trezo": "./dist/cli.mjs"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm",
    "dev": "tsx src/cli.ts init",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "publish:default": "npm publish",
    "publish:increment": "npm version patch --no-git-tag-version && npm publish"
  },
  "homepage": "https://trezosite.vercel.app/docs/cli",
  "bugs": {
    "url": "https://github.com/trezo-labs/packages/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trezo-labs/packages.git"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.mjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.mts",
    "LICENSE",
    "README.md"
  ],
  "devDependencies": {
    "@types/degit": "^2.8.6",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "degit": "^2.8.4",
    "inquirer": "^13.3.2",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  },
  "keywords": [
    "web3",
    "cli",
    "typescript",
    "ethereum",
    "blockchain",
    "dapp",
    "scaffold",
    "starter",
    "template",
    "degit",
    "project-generator",
    "developer-tool",
    "nodejs",
    "automation",
    "web3-architecture"
  ]
}
